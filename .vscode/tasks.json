{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile payroll",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\compile.ps1"
            ],
            "group": "build",
            "problemMatcher": "$javac"
        },
        {
            "label": "run payroll",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\run.ps1"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "test payroll",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\test.ps1"
            ],
            "group": "test",
            "problemMatcher": []
        }
    ]
}
